      ],
      "objdata": {
        "OnDamageActions": [ // this code makes the prospector tnt reappear and ignite when taking fire damage
          {
            "kind": "If",
            "condition": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "dirty"
              },
              "kind": "&&",
              "right": {
                "left": {
                  "kind": "GetObjectProperty",
                  "object": {
                    "kind": "GetContextObject",
                    "name": "damageDetails"
                  },
                  "property": "damageType"
                },
                "kind": "==",
                "right": 1 // fire damage type
              },
            },
            "then": [
              {
                "kind": "SetObjectProperty",
                "property": "dirty",
                "value": false
              },
              {
                "kind": "SetObjectProperty",
                "property": "ignited",
                "value": true
              }
            ]
          }
        ]
      }

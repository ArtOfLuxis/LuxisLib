      ],
      "objdata": {
        "DamageMultiplierAfterHit": 3,
        "PierceOverride": {
          "Amount": { "min": 4, "max": 4 },
          "PlayHitSound": true,
          "PlayHitParticle": true,
        },
        "EffectDamageMultiplier": [
          {
            "Effects": ["chill", "freeze"],
            "RequireAllEffects": false,
            "MinDuration": 0,
            "DamageMultiplier": 2.5
          }
        ]
      }
    },
    {
      "objclass": "ProjectileProperties",
      "aliases": [

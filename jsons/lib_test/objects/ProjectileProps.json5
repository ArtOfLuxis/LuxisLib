        "LobberProjectileSpread": [
          {
            "ProjectileType": "cabbage",
            "ProjectileAmount": 5,
            "ProjectileLaneOffsets": [{ "min": -4, "max": 4 }],
            "DecimalLaneOffsets": false,
            "FlightTimeMultiplier": 0.5,
            "TargetLockMode": {
              // setting to true will make the projectiles lock onto the first target in the
              // new lane instead of around the original target when possible
              "LockOnFirstEnemy": true,
              // setting to true will make LockOnFirstEnemy try to find zombies even behind the projectile's origin
              "IgnoreOriginColumn": true,
              "OriginColumnOffset": 0,
              "IgnoreEmptyLanesIfPossible": true,
              "PrioritizeTombs": true,
              "IgnoreTombs": false,
              "RandomizeTargetsInsteadOfDistancePriority": false,
              "InvertDistancePriority": false,
              "TargetColumnOffsets": [{ "min": 0, "max": 0 }],
              "DecimalColumnOffsets": false,
              "EvenlyDistributeProjectiles": true,
              "MaxDistributionTargets": 5,
              "ForceSpecificColumnTarget": null, // look at snowdrop for this
              "InstantlyHitTarget": false,
              "AllowTargetsOutsideLawn": false
            },
            "FirstProjectileInterval": 0,
            "ProjectileInterval": 0.05,
            "ProjectilesPerInterval": 1,
            "CenterOffset": { "x": 0, "y": 0 },

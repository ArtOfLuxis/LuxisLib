        "Damage": 0
      }
    },
    {
      "objclass": "ProjectileProperties",
      "aliases": [
        "pea"
      ],
      "objdata": {
        "ColorMult": { "r": 0.5, "g": 0.5, "b": 0.5 },
        "CanBePeaVineBuffed": false,
        "OnHitActions": [
          {
            "kind": "InvokeObjectMethod",
            "method": "setPerfume",
            "args": [5]
          },
          {
            "kind": "If",
            "condition": {
              "left": { "left": 75, "kind": ">", "right": {
                "kind": "GetObjectProperty",
                "object": {
                  "kind": "GetContextObject",
                  "name": "target"
                  // the object always defaults to target if not specified so you dont have to specify it
                },
                "property": "haveSun"
              }},
              "kind": "&&",
              "right": {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetContextObject",
                  "name": "target"
                },
                "method": "isAlive",
                "args": []
              }
            },
            "then": [
              {
                "kind": "SetObjectProperty",
                "object": {
                  "kind": "GetContextObject",
                  "name": "target"
                },
                "property": "haveSun",
                "value": 75
              },
              {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetContextObject",
                  "name": "target"
                },
                "method": "setSunBeanParticleCD",
                "args": [0.5]
              }
            ],
            "else": []
          }
        ]
      }
    },
    {
      "objclass": "ProjectileProperties",
      "aliases": [
        "pea_snow"
      ],
      "objdata": {
        "OnEnableActions": [
          {
            "kind": "SetObjectProperty",
            "property": "followRotation",
            "value": false // makes the projectile not follow the movement direction
          },
          {
            "kind": "SetObjectProperty",
            "property": "bodyOmega",
            "value": 3 // makes the projectile spin clockwise 180 degrees/s
          }
        ],
        "OnHitActions": [ // deals 2.5% of zombie's max hp as damage
          {
            "kind": "InvokeObjectMethod",
            "method": "defaultDealDamage",
            "args": [{
              "kind": "CreateDamageDetails",
              "damage": {
                "left": { "kind": "GetObjectProperty", "property": "toughness" },
                "kind": "*",
                "right": 0.025
              },
              "armorProtection": true,
              "armorKnockSound": true,
              "bodyKnockSound": true,
              "damageDirection": {
                "kind": "CreateVec2",
                "x": 0,
                "y": 15
              },
              "damageType": "physicle",
              "flash": true,
              "armorAlsoDamagedWhenNotProtecting": false,
              "bugKiller": false,
              "balloonKiller": false,
              "shockRGB": 1, // no idea what this does
              "DamageScaleForArmorRack": 1
            }]
          }
        ]
      }
    },

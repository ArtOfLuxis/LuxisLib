{
  "version": 1,
  "objects": [
    {
      "objclass": "LuxisLibProps",
      "aliases": [
        "LuxisLibProps"
      ],
      "objdata": {
        // general
        "MaxSunAmount": 999999, // default value is 9900
        "FastForwardSpeed": 3, // default value is 1.5
        "ImitaterSlotPlant": "wallnut",  // default value is "imitater"

        "YetiResetTimesPerDay": 86400,
        "DecodeResetTimesPerDay": 86400,
        "ClearDecodeGemTextOnRefresh": false,

        "SunValueOverrides": {
          "5": 5,
          "25": 25,
          "50": 49,
          "75": 75
        },
        "SunDropsOverride": {
          "5": ["SunTiny"],
          "25": ["SunSmall"],
          "50": ["SunMid"],
          "75": ["SunLarge"],
          "100": ["SunMid", "SunMid"],
          "100001": [
            {
              "Name": "PlantCardDropped",
              "PlantTypes": ["peashooter", "sunflower", "wallnut"]
            }
          ],
          "100002": ["plantFood", "SunBomb", "Gem", "Sprout", "CoinGold", "CoinSilver"]
        },
        "PlantSunCostFontScale": 0.75,
        "PlantSunCostHeightScale": 1,


        // decoding minigame
        "DecodeGemFormula": "\
          Math.round(\
              BASE_PLANTS * CODE_PLANTS * \
              Math.exp(-Math.pow(GUESSES / 8, 2))\
          ) + 9999\
        ", // use \ for new lines
        // this is the vanilla formula but adds 9999 to it
        "DecodeRecordScale": { "x": 0.7, "y": 0.7 },
        "DecodeRecordPadding": 15,
        "DecodeRecordSpacingX": 0,
        "DecodeRecordSpacingY": 10,
        "DecodeMergePlantCardsScale": { "x": 0.9, "y": 0.9 },
        "DecodeMergePlantCardsScaleDecrementPerPlant": 0.013,
        "DecodeBasePlantCardsScale": { "x": 0.6, "y": 0.6 },
        "DecodeBasePlantCardsSpacingX": 2,
        "DecodeBasePlantCardsSpacingY": 2,
        "DecodeBasePlantsAmountRange": [1, 30],
        "DecodeBasePlantsReplace": false,
        "DecodeBasePlants": [
          "pokra", "repeater", "lilypad", "lilypad", "peashooter", "lilypad", "lilypad"
        ],
        "DecodeCodePlantsAmountRange": [1, 60],
        "DecodeCodePlantsReplace": false,
        "DecodeCodePlants": [
          {
            "PlantA": "pokra",
            "PlantB": "wallnut",
            "Target": "lilypad"
          },
          {
            "PlantA": "cabbagepult",
            "PlantB": "wallnut",
            "Target": "tumbleweed"
          },
          {
            "PlantA": "repeater",
            "PlantB": "peashooter",
            "Target": "threepeater"
          },
          {
            "PlantA": "threepeater",
            "PlantB": "peashooter",
            "Target": "gatlingpea"
          },
          {
            "PlantA": "gatling",
            "PlantB": "peashooter",
            "Target": "megagatlingpea"
          }
        ],


        // plants
        "GlacierShroomSaturation": -1, // default is 0.5
        "PeaVineDamageBoost": 10, // default is 1.5


        // projectiles
        "ProjectileEnumAdd": [],


        // worlds and levels
        "ForceSkipTutorial": true,
        "StartingWorlds": ["pirate", "future"],
        "WorldOrder": [
          // deleting a world from here won't remove it from the order and
          // will just cause the world to be in front the ones in the list
          "Future",
          "Crack",
          "Pirate",
          "Unknown",
          "Sky",
          "Modern",
          "Egypt",
          "Cowboy",
          "Dark",
          "LostCity",
          "Beach",
          "Dino",
          "IceAge",
          "Kongfu",
          "Eighties",
        ],
        "ArcadeCustomLevels": {
          // only adds levels the first time you open arcade after you open the main menu
          "DEBUG": {
            "custom_level_test": "Level 1"
          },
          "Rhythm": {
            "custom_level_test": "Level 2"
          },
          "Floawerpot": {
            "custom_level_test": "Level 3"
          },
          "Shooting Starfruit": {
            "custom_level_test": "Level 4"
          },
          "Random Plants": {
            "custom_level_test": "Level 5"
          },
          "Random Zomboss Fight": {
            "custom_level_test": "Level 6"
          },
          "Bank Theft": {
            "custom_level_test": "Level 7"
          },
          "Beghouled": {
            "custom_level_test": "Level 8"
          },
          "Dangerroom": {
            "custom_level_test": "Level 9"
          }
        },


        // zombies
        "ZombieInvisibilityPotionOpacity": 0.2, // default value is 0.5
        "ZombieChillSpeedMultiplier": 0.5, // default value is 0.5
        "ZombiePerfumeSpeedMultiplier": 0.5, // default value is 0.5
        "ZombieSapSpeedMultiplier": 0.5, // default value is 0.5
        "ZombieDarkmatterHealthRatioMultiplier": 0.75, // default value is 0.75, lowering this will make lower hp zombies less affected
        "ZombieDarkmatterSpeedMultiplier": 1, // default value is 1, total speed multiplier when affected by darkmatter
        "ZombieScaredByTyrannoSpeedMultiplier": 4, // default value is 4
        "SandboxZombies": [
          // there is no original list since the game just uses all zombie ids
          // so you'd have to recreate the original list by hand if you want to use it
          // or you could just copy the almanac list from ZombieFeatures
          "tutorial",
          "tutorial_gargantuar",
          "dark_gargantuar",
          "tutorial_armor1",
          "tutorial_armor2",
          "tutorial_armor3",
          "tutorial_armor4",
          "pirate_armor1",
          "pirate_armor2",
          "explorer",
          "tutorial_flag",
          "tomb_raiser",
          "beach_surfer",
          "lostcity_impporter",
          "modern_allstar",
          "zomboni",
          "prospector",
          "dino_bully",
          "iceage_hunter_veteran",
          "lostcity_crystalskull",
          "kongfu_bomb",
          "dino_armor2",
          "lawn",
          "lawn_armor1"
        ],
        "ZombieEnumAdd": [
          // adding a zombie to the ZombieEnum allows you to properly use custom ZombieFeatures (in the almanac etc)
          "tutorial_armor3"
        ],


        // JSON hooks
        "JSONActionHooks": [
          {
            "className": "PerfumeShroomPlant",
            "method": "specialOnLaneChange",
            "actions": [] // just makes the original method do nothing
            //(makes perfume shroom be on the same layer as all other plants instead of on top)
          },
          {
            "className": "PerfumeShroomPlant",
            "method": "explode",
            "thisVariable": "this",
            "originalCallVariable": "callOriginal",
            "argsVariable": "args",
            "returnVariable": "return",
            "actions": [ // makes perfume shroom stall on explosion
              {
                "kind": "InvokeObjectMethod",
                "object": { "kind": "GetContext" },
                "method": "callOriginal",
                "args": { "kind": "GetContextObject", "name": "args" }
              },
              {
                "kind": "For",
                "iterable": {
                  "kind": "InvokeObjectMethod",
                  "method": "inLane.zombiePool"
                },
                "variable": "zombie",
                "actions": [
                  {
                    "kind": "InvokeObjectMethod",
                    "object": { "kind": "GetContextObject", "name": "zombie" },
                    "method": "setPerfume",
                    "args": [{
                      "kind": "GetObjectProperty",
                      "property": "___NormalStallDuration"
                    }]
                  }
                ]
              }
            ]
          },




          {
            "className": "EscapeRootPlant",
            "method": "animationOnComplete",
            "thisVariable": "this",
            "originalCallVariable": "callOriginal",
            "argsVariable": "args",
            "returnVariable": "return",
            "actions": [ // kills the escape root after swapping places with another plant
              {
                "kind": "If",
                "condition": {
                  "kind": "GetObjectProperty",
                  "property": "switching"
                },
                "then": [
                  {
                    "kind": "SetObjectProperty",
                    "property": "deathAnm",
                    "value": "Death_Silently"
                  },
                  {
                    "kind": "InvokeObjectMethod",
                    "method": "die",
                    "args": [true, false, false]
                  }
                ]
              },
              {
                "kind": "InvokeObjectMethod",
                "object": { "kind": "GetContext" },
                "method": "callOriginal",
                "args": { "kind": "GetContextObject", "name": "args" }
              },
            ]
          }
        ]
      }
    },

    { // lets you use this level in the arcade (look at ArcadeCustomLevels) and with worldmap modding
      "objclass": "CustomLevelDefinition",
      "aliases": [
        "custom_level_test"
      ],
      "objdata": {
        "LevelModules": [
          {
            "objclass": "LevelDefinition",
            "objdata": {
              "Description": "[PLAYERS_HOUSE]",
              "LevelNumber": 4,
              "Loot": "RTID(NoLoot@LevelModules)",
              "Modules": [
                "RTID(500MaxSunAmountProps@CurrentLevel)",
                "RTID(StandardIntro@LevelModules)",
                "RTID(DefaultSunDropper@LevelModules)",
                "RTID(ZombiesDeadWinCon@LevelModules)",

                },
                {
                  "Type": "RTID(tutorial@ZombieTypes)"
                }
              ]
            }
          },
        ]
      }
    },
    {
      "objclass": "CustomLevelDefinition",
      "aliases": [
        "custom_level_test2"
      ],
      "objdata": {
        "LevelModules": [
          {
            "objclass": "LevelDefinition",
            "objdata": {
              "Description": "[PLAYERS_HOUSE]",
              "LevelNumber": 4,
              "Loot": "RTID(NoLoot@LevelModules)",
              "Modules": [
                "RTID(OnUpdateActions@CurrentLevel)",
                "RTID(OnStartActions@CurrentLevel)",
                "RTID(StandardIntro@LevelModules)",
                "RTID(DefaultSunDropper@LevelModules)",
                "RTID(ZombiesDeadWinCon@LevelModules)",
                "RTID(FrontLawnMowers@LevelModules)",
                "RTID(SeedBank@CurrentLevel)",
                "RTID(DefaultZombieWinCondition@LevelModules)",
                "RTID(NewWaves@CurrentLevel)"
              ],
              "Name": "[TUTORIAL_LEVEL_NAME]",
              "StageModule": "RTID(TutorialStage@LevelModules)",
            }
          },
          {
            "aliases": [
              "OnStartActions"
            ],
            "objclass": "LLSetOnStartActions",
            "objdata": {
              "Actions": [{
                "kind": "SetObjectProperty",
                "property": "___IZombieColumns",
                "value": 3
              }]
            }
          },
          {
            "aliases": [
              "OnUpdateActions"
            ],
            "objclass": "LLSetOnUpdateActions",
            "objdata": {
              "Actions": [
                {
                  "kind": "If",
                  "condition": {
                    "kind": "ArrayAllObjects",
                    "array": { "kind": "GetObjectProperty", "property": "currentMowerLanes" },
                    "variable": "mowerExists",
                    "condition": {
                      "left": { "kind": "GetContextObject", "name": "mowerExists" },
                      "kind": "==",
                      "right": false
                    }
                  },
                  "then": [
                    {
                      "kind": "InvokeObjectMethod",
                      "method": "victory"
                    }
                  ]
                }
              ]
            }
          },
          {
            "aliases": [
              "SeedBank"
            ],
            "objclass": "SeedBankProperties",
            "objdata": {
              "SuppressObjectiveTip": true,
              "SelectionMethod": "chooser"
            }
          },
          {
            "aliases": [

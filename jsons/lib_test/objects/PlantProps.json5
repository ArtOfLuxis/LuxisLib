        "jackolantern"
      ],
      "objclass": "PlantProperties",
      "objdata": {
        "DPS": 0,
        "DPSPlantfood": 200,
        "ShootDuration": 0,
        "RechargeTime": 99999999999,
        "Distance": 0,
        "PlantfoodFireCount": 10,
        "Cooldown": 25,
        "CooldownFrom": 0,
        "SunCost": 175,
        "BeghouledCost": 1000,
        "Toughness": 1000,
        "Family": "Explosive",
        "ImmuneToIceblock": true,
        "OnEnableActions": [
          {
            "kind": "SetObjectProperty",
            "property": "___ClickCooldown",
            "value": 0
          }
        ],
        "OnUpdateActions": [
          {
            "kind": "SetObjectProperty",
            "property": "___ClickCooldown",
            "value": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": "-",
              "right": {
                "kind": "GetContextObject",
                "name": "deltaTime"
              }
            }
          },
          {
            "kind": "If",
            "condition": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": ">",
              "right": 0
            },
            "then": [
              {
                "kind": "SetObjectProperty",
                "property": "baseColor",
                "value": {
                  "kind": "InvokeConstructor",
                  "object": {
                    "kind": "GetObjectProperty",
                    "property": "baseColor"
                  },
                  "args": [
                    80,
                    80,
                    80,
                    255
                  ]
                }
              }
            ],
            "else": [
              {
                "kind": "SetObjectProperty",
                "property": "baseColor",
                "value": {
                  "kind": "InvokeConstructor",
                  "object": {
                    "kind": "GetObjectProperty",
                    "property": "baseColor"
                  },
                  "args": [
                    255,
                    255,
                    255,
                    255
                  ]
                }
              }
            ]
          }
        ],
        "OnLeftClickActions": [
          {
            "kind": "If",
            "condition": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": "<=",
              "right": 0
            },
            "then": [
              {
                "kind": "SetObjectProperty",
                "property": "___ClickCooldown",
                "value": 25
              },
              {
                "kind": "InvokeObjectMethod",
                "method": "shootEnd"
              },
              {
                "kind": "InvokeObjectMethod",
                "method": "shootEnd"
              },
              {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetProjectileShootingFunctions"
                },
                "method": "shootOnePea",
                "args": [
                  "jackolantern_spread",
                  {
                    "kind": "GetObjectProperty",
                    "property": "worldPosition"
                  },
                  40,
                  {
                    "kind": "GetObjectProperty",
                    "property": "inLane.prjLayer"
                  },
                  {
                    "kind": "CreateVec2",
                    "x": 8,
                    "y": 0
                  },
                  {
                    "kind": "GetCharacterType",
                    "name": "zombie"
                  },
                  false
                ],
              }
            ]
          }
        ],
        "WarmingRadius": {
          "PulseInitialDelay": 5,
          "PulseCooldown": 10,
          "GridItemDamage": 200
        }
      }
    },

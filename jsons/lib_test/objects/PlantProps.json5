    { // hexar's sun statue
      "objclass": "PlantProperties",
      "aliases": [
        "primalsunflower"
      ],
      "objdata": {
        "ColorOffset": { "r": 0, "g": 0, "b": 0, "holo": 0, "s": -1 },
        "SpeedScale": 0.00001,
        "OnEnableActions": [
          {
            "kind": "SetObjectProperty",
            "property": "eaterDetectable",
            "value": false
          },
          {
            "kind": "SetObjectProperty",
            "property": "smasherDetectable",
            "value": false
          },
          {
            "kind": "SetObjectProperty",
            "property": "invincible",
            "value": true
          },
          {
            "kind": "SetObjectProperty",
            "property": "foodable",
            "value": false
          },
          {
            "kind": "SetObjectProperty",
            "property": "___ClickCooldown",
            "value": 0
          }
        ],
        "OnUpdateActions": [
          {
            "kind": "SetObjectProperty",
            "property": "___ClickCooldown",
            "value": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": "-",
              "right": {
                "kind": "GetContextObject",
                "name": "deltaTime"
              }
            }
          },
          {
            "kind": "If",
            "condition": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": ">",
              "right": 0
            },
            "then": [
              {
                "kind": "SetObjectProperty",
                "property": "baseColor",
                "value": {
                  "kind": "InvokeConstructor",
                  "object": {
                    "kind": "GetObjectProperty",
                    "property": "baseColor"
                  },
                  "args": [80, 80, 80, 255]
                }
              }
            ],
            "else": [
              {
                "kind": "SetObjectProperty",
                "property": "baseColor",
                "value": {
                  "kind": "InvokeConstructor",
                  "object": {
                    "kind": "GetObjectProperty",
                    "property": "baseColor"
                  },
                  "args": [255, 255, 255, 255]
                }
              }
            ]
          }
        ],
        "OnLeftClickActions": [
          {
            "kind": "If",
            "condition": {
              "left": {
                "kind": "GetObjectProperty",
                "property": "___ClickCooldown"
              },
              "kind": "<=",
              "right": 0
            },
            "then": [
              {
                "kind": "SetContextObject",
                "name": "SunValue",
                "object": 50
              },
              {
                "kind": "SetContextObject",
                "name": "EffectTime",
                "object": 10
              },
              {
                "kind": "SetContextObject",
                "name": "LevelPlay",
                "object": {
                  "kind": "GetObjectProperty",
                  "object": {
                    "kind": "GetSystemModule",
                    "name": "levelController"
                  },
                  "property": "LevelPlay"
                }
              },
              {
                "kind": "SetContextObject",
                "name": "3x3Area",
                "object": {
                  "kind": "CreateRectangle",
                  "node": {
                    "kind": "GetObjectProperty",
                    "property": "node"
                  },
                  "width": 3,
                  "height": 3
                }
              },
              {
                "kind": "SetContextObject",
                "name": "CurrentLnC",
                "object": {
                  "kind": "GetObjectProperty",
                  "property": "inLnC"
                }
              },
              {
                "kind": "SetContextObject",
                "name": "CurrentLane",
                "object": {
                  "kind": "GetObjectProperty",
                  "object": {
                    "kind": "GetContextObject",
                    "name": "CurrentLnC"
                  },
                  "property": "inLane"
                }
              },
              {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetContextObject",
                  "name": "LevelPlay"
                },
                "method": "shakeScreen",
                "args": [0.6]
              },
              {
                "kind": "SetObjectProperty",
                "property": "___ClickCooldown",
                "value": 25
              },
              {
                "kind": "For",
                "variable": "lane",
                "iterable": [
                  {
                    "kind": "GetContextObject",
                    "name": "CurrentLane"
                  },
                  {
                    "kind": "GetObjectProperty",
                    "object": {
                      "kind": "GetContextObject",
                      "name": "CurrentLane"
                    },
                    "property": "UpperLane"
                  },
                  {
                    "kind": "GetObjectProperty",
                    "object": {
                      "kind": "GetContextObject",
                      "name": "CurrentLane"
                    },
                    "property": "LowerLane"
                  }
                ],
                "actions": [
                  {
                    "kind": "For",
                    "variable": "zombie",
                    "iterable": {
                      "kind": "InvokeObjectMethod",
                      "object": {
                        "kind": "GetContextObject",
                        "name": "lane"
                      },
                      "method": "zombiePool"
                    },
                    "actions": [
                      {
                        "kind": "If",
                        "condition": {
                          "kind": "InvokeObjectMethod",
                          "object": {
                            "kind": "GetContextObject",
                            "name": "3x3Area"
                          },
                          "method": "judgeCrossRec",
                          "args": [
                            {
                              "kind": "GetObjectProperty",
                              "object": {
                                "kind": "GetContextObject",
                                "name": "zombie"
                              },
                              "property": "bodyRecReal"
                            }
                          ],
                        },
                        "then": [
                          {
                            "kind": "InvokeObjectMethod",
                            "object": {
                              "kind": "GetContextObject",
                              "name": "zombie"
                            },
                            "method": "setChill",
                            "args": [
                              {
                                "kind": "GetContextObject",
                                "name": "EffectTime"
                              }
                            ]
                          },
                          {
                            "kind": "If",
                            "condition": {
                              "left": {
                                "kind": "GetContextObject",
                                "name": "SunValue"
                              },
                              "kind": ">",
                              "right": {
                                "kind": "GetObjectProperty",
                                "object": {
                                  "kind": "GetContextObject",
                                  "name": "zombie"
                                },
                                "property": "haveSun"
                              }
                            },
                            "then": [
                              {
                                "kind": "If",
                                "condition": {
                                  "kind": "InvokeObjectMethod",
                                  "object": {
                                    "kind": "GetContextObject",
                                    "name": "zombie"
                                  },
                                  "method": "isAlive"
                                },
                                "then": [
                                  {
                                    "kind": "SetObjectProperty",
                                    "object": {
                                      "kind": "GetContextObject",
                                      "name": "zombie"
                                    },
                                    "property": "haveSun",
                                    "value": {
                                      "kind": "GetContextObject",
                                      "name": "SunValue"
                                    }
                                  },
                                  {
                                    "kind": "InvokeObjectMethod",
                                    "object": {
                                      "kind": "GetContextObject",
                                      "name": "zombie"
                                    },
                                    "method": "setSunBeanParticleCD",
                                    "args": [
                                      {
                                        "kind": "GetContextObject",
                                        "name": "EffectTime"
                                      }
                                    ]
                                  },
                                  {
                                    "kind": "Sleep",
                                    "cloneContext": true,
                                    "time": {
                                      "kind": "GetContextObject",
                                      "name": "EffectTime"
                                    },
                                    "object": {
                                      "kind": "GetContextObject",
                                      "name": "zombie"
                                    },
                                    "actions": [
                                      {
                                        "kind": "SetObjectProperty",
                                        "object": {
                                          "kind": "GetContextObject",
                                          "name": "zombie"
                                        },
                                        "property": "haveSun",
                                        "value": 0
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]

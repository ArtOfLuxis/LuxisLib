    {
      "objclass": "PlantProperties",
      "aliases": [
        "murkadamia"
      ],
      "objdata": {
        "OnEnableActions": [ // this code kills murkadamia after 4s and spawns a tallnut in its place
          {
            "kind": "Sleep",
            "time": 4,
            "actions": [
              {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetObjectProperty",
                  "property": "inLnC"
                },
                "method": "SpawnPlantByType",
                "args": ["tallnut", false, true, false, true, false, true]
              },
              {
                "kind": "InvokeObjectMethod",
                "method": "die",
                "args": [false, false, false, false]
              },
              {
                "kind": "InvokeObjectMethod",
                "object": {
                  "kind": "GetObjectProperty",
                  "property": "node"
                },
                "method": "destroy",
              }
            ]
          }
        ]
      }
    },
    {
      "objclass": "PlantProperties",
      "aliases": [
        "tallnut"
      ],
      "objdata": {
        "SmashDamageInsteadOfDeath": {
          "forcedDamage": null // tries to take SmashDamage from a zombie, defaults to 1500
        },
        "OnUpdateActions": [ // this code makes tallnut heal 75 hp/second
          {
            "kind": "InvokeObjectMethod",
            "method": "heal",
            "args": [{
              "left": 75,
              "kind": "*",
              "right": {
                "kind": "GetContextObject",
                "name": "deltaTime"
              }
            }]
          }
        ],
        "OnEatenActions": [ // this code makes a tallnut spawn a hypnotized zombie when eaten
          {
            "kind": "SpawnZombie",
            "lnc": {
              "kind": "GetObjectProperty",
              "property": "inLnC"
            },
            "type": "dino_armor2",
            "spawnStyle": "dirtspawn",
            "playSound": true,
            "columnOffset": -0.5,
            "delay": 0,
            "playRiseAnimation": true,
            "reversed": false,
            "hypnotized": true
          }
        ]
      }
    },
    {
      "objclass": "PlantProperties",
      "aliases": [
        "iceburg"
      ],
      "objdata": {
        "OnEnableActions": [
          {
            "kind": "SetObjectProperty",
            "property": "___existTime",
            "value": 0
          }
        ],
        "OnUpdateActions": [ // this code changes iceburg's size from -0.5 to 1 and back over time
          {
            "kind": "IncrementObjectProperty",
            "property": "___existTime",
            "value": {
              "kind": "GetContextObject",
              "name": "deltaTime"
            }
          },
          {
            "kind": "SetObjectProperty",
            "property": "plantScale",
            "value": {
              "left": 0.25,
              "kind": "+",
              "right": {
                "left": 0.75,
                "kind": "*",
                "right": {
                  "kind": "sin",
                  "value": {
                    "left": {
                      "kind": "GetObjectProperty",
                      "property": "___existTime"
                    },
                    "kind": "*",
                    "right": 4
                  }
                }
              }
            }
          }
        ]
      }
    },
